#!/usr/bin/env bash
# code-graph post-commit hook: incremental index update.
# Failures are silent so they never block a commit.

set -u

if ! command -v code-graph >/dev/null 2>&1; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$ROOT" || exit 0

if [ ! -d ".codegraph" ]; then
  exit 0
fi

code-graph update >/dev/null 2>&1 || true
exit 0
